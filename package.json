{
    "name": "aiprcodereview",
    "version": "2.0.6",
    "keywords": [
        "AI pull request code review",
        "Azure DevOps Pipeline",
        "Gemini Code Review",
        "OpenAI Code Review",
        "Grok Code Review",
        "Claude Code Review",
        "GitHub Copilot Code Review"
    ],
    "author": "Lawrence Shen",
    "license": "MIT",
    "description": "Generates a code review for a pull request using AI.",
    "main": "dist/index.js",
    "scripts": {
        "clean": "shx rm -rf dist",
        "test": "cross-env TS_NODE_PROJECT=tsconfig.test.json mocha -r ts-node/register test/**/*.spec.ts",
        "typecheck": "tsc --noEmit",
        "copy": "shx cp src/task.json dist/task.json && shx cp images/extension-icon-small.png dist/icon.png",
        "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=cjs --sourcemap",
        "build": "node scripts/sync-taskjson.js && npm run clean && npm run typecheck && npm run bundle && npm run copy",
        "debug": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=cjs --sourcemap && shx cp src/task.json dist/task.json && node --env-file=./devscripts/.env ./dist/index.js --debug",
        "devscripts:ai": "esbuild devscripts/ai-comment.ts --bundle --platform=node --target=node22 --outfile=dist-dev/devscripts/ai-comment.js --format=cjs --sourcemap && node --env-file=./devscripts/.env ./dist-dev/devscripts/ai-comment.js",
        "devscripts:pr-changes": "esbuild devscripts/pr-changes.ts --bundle --platform=node --target=node22 --outfile=dist-dev/devscripts/pr-changes.js --format=cjs --sourcemap && node --env-file=./devscripts/.env ./dist-dev/devscripts/pr-changes.js",
        "devscripts:pr-comment": "esbuild devscripts/pr-comment.ts --bundle --platform=node --target=node22 --outfile=dist-dev/devscripts/pr-comment.js --format=cjs --sourcemap && node --env-file=./devscripts/.env ./dist-dev/devscripts/pr-comment.js",
        "devscripts:test-copilot": "esbuild devscripts/test-copilot-cli.ts --bundle --platform=node --target=node22 --outfile=dist-dev/devscripts/test-copilot-cli.js --format=cjs --sourcemap && node --env-file=./devscripts/.env ./dist-dev/devscripts/test-copilot-cli.js",
        "devscripts:inline-comment": "esbuild devscripts/inline-comment.ts --bundle --platform=node --target=node22 --outfile=dist-dev/devscripts/inline-comment.js --format=cjs --sourcemap && node --env-file=./devscripts/.env ./dist-dev/devscripts/inline-comment.js",
        "packaging:install-tool": "npm install -g tfx-cli",
        "packaging:package": "npm run build && tfx extension create --manifest-globs vss-extension.json --output-path ./packages"
    },
    "dependencies": {
        "@github/copilot-sdk": "^0.2.1",
        "@octokit/rest": "^20.0.0",
        "axios": "^1.12.2",
        "azure-devops-node-api": "^15.1.1",
        "azure-pipelines-task-lib": "^5.2.1",
        "openai": "^6.7.0"
    },
    "devDependencies": {
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.9.1",
        "@types/sinon": "^21.0.0",
        "chai": "^6.2.2",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.0",
        "esbuild": "^0.25.11",
        "mocha": "^11.7.5",
        "shx": "^0.3.4",
        "sinon": "^21.0.1",
        "tfx-cli": "^0.23.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
