# ============================================================
# DevOps Connection Settings | DevOps 連線設定
# Configure Azure DevOps pipeline connection credentials | 設定 Azure DevOps Pipeline 連線憑證
# ============================================================
# Azure DevOps Organization URL | 組織網址
DevOpsOrgUrl=https://dev.azure.com/YourOrganization/
# Personal access token for DevOps API | 存取 DevOps API 的個人存取權杖
DevOpsAccessToken=YourDevOpsAccessToken
# Target project name | 目標專案名稱
DevOpsProjectName=YourDevOpsProjectName
# Target repository ID | 目標儲存庫 ID
DevOpsRepositoryId=YourDevOpsRespositoryId
# Pull request ID to review | 要審查的 PR 編號
DevOpsPRId=42

# ============================================================
# AI Provider Settings | AI 提供者設定
# Configure AI service provider, model, and API keys | 設定 AI 服務供應商、模型及 API 金鑰
# ============================================================
# Google Gemini API key | Google Gemini API 金鑰
GeminiAPIKey=YourGeminiAPIKey
# OpenAI API key | OpenAI API 金鑰
OpenAIAPIKey=YourOpenAIAPIKey
# xAI Grok API key | Grok (xAI) API 金鑰
GrokAPIKey=YourGrokAPIKey
# Anthropic Claude API key | Claude (Anthropic) API 金鑰
ClaudeAPIKey=YourClaudeAPIKey
# AI provider to use | 使用的 AI 供應商 (Google / OpenAI / Grok / Claude / GitHubCopilot)
AiProvider=GitHubCopilot
# Model name for selected provider | 所選供應商的模型名稱
# Available model reference names | 可用模型參考名稱:
#   gemini-2.5-flash / grok-3-mini
#   gpt-4.1 / gpt-5-mini / gpt-5.4
#   claude-haiku-4.5 / claude-sonnet-4.5 / claude-sonnet-4.6 / claude-opus-4.5
ModelName=gpt-5-mini

# ============================================================
# GitHub Copilot Settings | GitHub Copilot 特殊設定
# Configure GitHub Copilot token, CLI server, and timeout | 設定 GitHub Copilot 的 Token、CLI 伺服器與逾時
# ============================================================
# Optional: Remote Copilot server (e.g., "192.168.1.100:8080") | 選用：遠端 Copilot 伺服器位址
# GitHubCopilotServerAddress=localhost:8080
# GitHub Copilot personal access token | GitHub Copilot 個人存取權杖
GitHubCopilotToken=YourGitHubCopilotToken
# Request timeout in milliseconds | 請求逾時（毫秒），預設 300000ms（5 分鐘）
GitHubCopilotTimeout=300000

# ============================================================
# AI Generation Settings | AI 生成設定
# Control how the AI generates review responses | 控制 AI 產生審查回應的方式
# ============================================================
# Instruction source | 指令來源 (Built-in / Inline / File)
SystemInstructionSource=Built-in
# Inline instruction (used when SystemInstructionSource=Inline) | 行內系統指令（SystemInstructionSource=Inline 時使用）
SystemInstruction=
# Language for AI response | AI 回應語言
ResponseLanguage=Taiwanese (zh-TW)
# Max output tokens (leave empty for default) | 最大輸出 Token 數（留空使用預設值）
MaxOutputTokens=
# AI creativity 0.0~1.0 (lower = more deterministic) | AI 創意程度 0.0~1.0（越低越穩定）
Temperature=0.2

# ============================================================
# Diff Filter Settings | 差異過濾設定
# Specify which file types to include or exclude from review | 設定審查包含或排除的檔案類型
# ============================================================
# File extensions to include in review | 要納入審查的副檔名
FileExtensions=.cs,.ts,.js,.aspx,.html
# Binary file extensions to skip | 要跳過的二進位檔案副檔名
BinaryExtensions=

# ============================================================
# Review Mode Settings | 審查模式設定
# Control how the AI reviews PR changes | 控制 AI 審查 PR 變更的行為
# ============================================================
# true: use only diffs; false: use full file content | true: 僅使用差異內容；false: 使用完整檔案內容
EnableThrottleMode=true
# true: print prompts and AI response; false: silent | true: 輸出提示與 AI 回應；false: 靜默模式
ShowReviewContent=true
# true: review only latest push; false: review entire PR | true: 僅審查最新 push；false: 審查整個 PR
EnableIncrementalDiff=true
# true: post review result back to PR; false: skip posting (Debug mode) | true: 將審查結果寫回 PR；false: 不寫回 PR（Debug 模式）
WriteReviewResult=false

# ============================================================
# Inline Comment Settings | 行內評論設定
# Configure AI inline commenting behavior | 設定 AI 行內評論的行為
# ============================================================
# true: post precise line-level comments; false: post single summary comment
# true: 發佈精準行號行內評論；false: 發佈單一摘要評論
EnableInlineComments=true
# true: merge multiple issues per file into one comment; false: one comment per issue
# true: 同一檔案問題合併為一則評論；false: 每個問題各自一則評論
GroupInlineCommentsByFile=false
# false: report only critical/warning; true: also report suggestions
# false: 僅回報 critical/warning；true: 同時回報 suggestion 級別問題
InlineStrictMode=false 